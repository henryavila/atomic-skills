{
  "name": "@henryavila/atomic-skills",
  "version": "2.0.0",
  "description": "Stop rewriting prompts. Install optimized developer skills in any AI IDE.",
  "type": "module",
  "bin": {
    "atomic-skills": "bin/cli.js"
  },
  "files": [
    "bin/",
    "src/",
    "scripts/",
    "skills/",
    "meta/",
    "dist/dashboard/",
    "README.md",
    "LICENSE",
    "assets/"
  ],
  "scripts": {
    "test": "node --test \"tests/**/*.test.js\" \"test/**/*.test.js\"",
    "test:hooks": "bash tests/hooks/session-start.test.sh && bash tests/hooks/stop.test.sh && bash tests/hooks/pre-write.test.sh && bash tests/hooks/pre-commit.test.sh",
    "new-skill": "node scripts/new-skill.js",
    "validate-skills": "node scripts/validate-skills.js",
    "validate-state": "node scripts/validate-state.js",
    "build:aideck-schema": "node scripts/build-aideck-consumer-schema.mjs",
    "detect-scope": "node scripts/detect-scope.js",
    "generate-readme": "node scripts/generate-readme.js",
    "generate-helpview-data": "node scripts/generate-helpview-data.js",
    "generate-skill-docs": "node scripts/generate-skill-docs.js",
    "generate-docs": "node scripts/generate-readme.js && node scripts/generate-helpview-data.js && node scripts/generate-skill-docs.js",
    "check-docs": "node scripts/generate-readme.js --check && node scripts/generate-helpview-data.js --check && node scripts/generate-skill-docs.js --check",
    "validate-catalog": "npm run validate-skills && npm run check-docs",
    "dev:dashboard": "vite --config vite.config.ts",
    "build:dashboard": "vite build --config vite.config.ts && node -e \"import{cpSync as c,rmSync as r,existsSync as e}from'fs';import{join as j}from'path';import{homedir as h}from'os';const p=j(h(),'.atomic-skills','dashboard');if(e(p))r(p,{recursive:true});c('dist/dashboard',p,{recursive:true});\"",
    "typecheck:dashboard": "tsc -p tsconfig.dashboard.json --noEmit",
    "prepare": "husky && git config core.hooksPath .husky",
    "prepublishOnly": "npm run build:dashboard"
  },
  "keywords": [
    "ai",
    "skills",
    "prompts",
    "claude",
    "cursor",
    "gemini",
    "codex",
    "copilot"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/henryavila/atomic-skills.git"
  },
  "homepage": "https://github.com/henryavila/atomic-skills#readme",
  "bugs": {
    "url": "https://github.com/henryavila/atomic-skills/issues"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "@henryavila/aideck": "^0.1.0",
    "@henryavila/tooling-installer": "file:../../../tooling-installer",
    "ajv": "^8.20.0",
    "picocolors": "^1.1.1",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@hono/node-server": "^1.19.14",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tailwindcss/vite": "^4.0.0",
    "@tanstack/react-query": "^5.59.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "chokidar": "^4.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "esbuild": "^0.25.12",
    "hono": "^4.12.23",
    "husky": "^9.1.7",
    "lucide-react": "^0.460.0",
    "open": "^10.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^7.0.0",
    "tailwind-merge": "^2.5.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "zod": "^3.25.76",
    "zod-to-json-schema": "^3.25.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
