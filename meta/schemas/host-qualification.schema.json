{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://atomic-skills.henryavila.com/schemas/host-qualification.schema.json",
  "title": "Host qualification manifest",
  "description": "Canonical support tier and adapter contract per PUBLIC_IDE_ID. operational requires versioned adapter + discovery/load/invoke ops; layout-only requires supportDeclared:false and a justification (no operational claim).",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "hosts"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1"
    },
    "hosts": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/hostEntry" }
    }
  },
  "$defs": {
    "hostEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "supportTier"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "description": "Must match a PUBLIC_IDE_ID from src/config.js"
        },
        "supportTier": {
          "type": "string",
          "enum": ["operational", "layout-only"]
        },
        "supportDeclared": {
          "type": "boolean",
          "description": "Must be false for layout-only; true only when operational with real probe contract"
        },
        "justification": {
          "type": "string",
          "minLength": 8,
          "description": "Required for layout-only — why operational support is not claimed"
        },
        "adapter": {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "version"],
          "properties": {
            "id": { "type": "string", "minLength": 1 },
            "version": { "type": "string", "minLength": 1 },
            "profile": {
              "type": "string",
              "description": "Tool-profile key in HOST_TOOL_PROFILES"
            },
            "discovery": { "type": "string", "minLength": 1 },
            "load": { "type": "string", "minLength": 1 },
            "invoke": { "type": "string", "minLength": 1 }
          }
        },
        "autoUpdate": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "capability": {
              "type": "string",
              "enum": ["session-start-hook", "none"]
            },
            "surface": {
              "type": "string",
              "description": "Relative path of the host hook surface when capability is session-start-hook"
            }
          }
        }
      }
    }
  }
}
