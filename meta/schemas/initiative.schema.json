{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://atomic-skills.henryavila.com/schemas/initiative.schema.json",
  "title": "atomic-skills Initiative frontmatter (schemaVersion 0.1)",
  "description": "Validates the YAML frontmatter of `.atomic-skills/initiatives/<slug>.md`. Mirrors aideck/src/schemas/project-status.ts:Initiative + Task. The `body` field of the TypeScript Initiative interface lives in the markdown body, NOT frontmatter — so it is not declared here. Standalone initiatives omit `parentPlan` and `phaseId`.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "slug",
    "title",
    "goal",
    "status",
    "branch",
    "started",
    "lastUpdated",
    "nextAction",
    "exitGates",
    "stack",
    "tasks",
    "parked",
    "emerged"
  ],
  "properties": {
    "schemaVersion": { "$ref": "common.schema.json#/$defs/schemaVersion" },
    "slug": { "$ref": "common.schema.json#/$defs/slug" },
    "title": { "type": "string", "minLength": 1 },
    "goal": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "description": "Concise one-line human summary of what this phase does (mirrors the plan phase descriptor's `summary`). Authored + user-validated at phase generation; shown on the dashboard Home (Agora callout)." },
    "status": {
      "type": "string",
      "enum": ["pending", "active", "paused", "done", "archived"]
    },
    "branch": { "type": ["string", "null"] },
    "started": { "$ref": "common.schema.json#/$defs/isoTimestamp" },
    "lastUpdated": { "$ref": "common.schema.json#/$defs/isoTimestamp" },
    "nextAction": { "type": ["string", "null"] },
    "parentPlan": { "$ref": "common.schema.json#/$defs/slug" },
    "phaseId": { "type": "string", "minLength": 1 },
    "audience": { "type": "string" },
    "tasksDone": {
      "type": "integer",
      "minimum": 0,
      "description": "Rollup precomputed by the project-status skill: count of tasks with status 'done'. Powers dashboard progress meters (aiDeck stays read-in-place / no compute engine). Recompute on every task mutation; see scripts/compute-rollups.js."
    },
    "tasksTotal": {
      "type": "integer",
      "minimum": 0,
      "description": "Rollup: tasks.length."
    },
    "gatesMet": {
      "type": "integer",
      "minimum": 0,
      "description": "Rollup: count of exitGates with status 'met'."
    },
    "gatesTotal": {
      "type": "integer",
      "minimum": 0,
      "description": "Rollup: exitGates.length."
    },
    "planActive": {
      "type": "boolean",
      "description": "Derived focus marker (scripts/reconcile-focus.js): true iff this initiative's parent plan has status 'active'. Scopes the Home timeline to active plans (the dashboard can't join plan→initiative). Never hand-authored."
    },
    "current": {
      "type": "boolean",
      "description": "Derived focus marker (scripts/reconcile-focus.js): true iff planActive AND this is the plan's currentPhase — i.e. the single 'AGORA' phase. Powers the Home focus callout. Never hand-authored."
    },
    "planTitle": {
      "type": "string",
      "description": "Derived denormalization (scripts/reconcile-focus.js): the parent plan's `title`. Lets a repeat-grouped widget (grouped by the parentPlan slug) label the group with the human plan title instead of the slug (the dashboard can't join plan→initiative). Never hand-authored."
    },
    "exitGates": {
      "type": "array",
      "items": { "$ref": "common.schema.json#/$defs/exitCriterion" }
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["paths"],
      "properties": {
        "paths": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "stack": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "title", "type", "openedAt"],
        "properties": {
          "id": { "type": "integer", "minimum": 1 },
          "title": { "type": "string", "minLength": 1 },
          "type": {
            "type": "string",
            "enum": ["task", "research", "validation", "discussion"]
          },
          "openedAt": { "$ref": "common.schema.json#/$defs/isoTimestamp" }
        }
      }
    },
    "tasks": {
      "type": "array",
      "items": { "$ref": "#/$defs/task" }
    },
    "parked": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["title", "surfacedAt", "fromFrame", "context"],
        "properties": {
          "title": { "type": "string", "minLength": 1 },
          "surfacedAt": { "$ref": "common.schema.json#/$defs/isoTimestamp" },
          "fromFrame": { "type": ["integer", "null"] },
          "context": { "$ref": "common.schema.json#/$defs/context" }
        }
      }
    },
    "emerged": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["title", "surfacedAt", "promoted", "context"],
        "properties": {
          "title": { "type": "string", "minLength": 1 },
          "surfacedAt": { "$ref": "common.schema.json#/$defs/isoTimestamp" },
          "promoted": { "type": "boolean" },
          "context": { "$ref": "common.schema.json#/$defs/context" }
        }
      }
    },
    "externalImports": {
      "type": "array",
      "items": { "$ref": "common.schema.json#/$defs/artifactRef" }
    },
    "references": {
      "type": "array",
      "items": { "$ref": "common.schema.json#/$defs/artifactRef" }
    },
    "crossTaskRefs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["fromTaskId", "toInitiativeSlug", "toTaskId", "relation"],
        "properties": {
          "fromTaskId": { "type": "string", "minLength": 1 },
          "toInitiativeSlug": { "$ref": "common.schema.json#/$defs/slug" },
          "toTaskId": { "type": "string", "minLength": 1 },
          "relation": {
            "type": "string",
            "enum": ["depends_on", "extends", "unblocks", "references"]
          },
          "note": { "type": "string" }
        }
      }
    }
  },
  "$defs": {
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "status", "lastUpdated"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "description": "Concise one-line human summary of what this task does — distinct from the label `title` and the longer `description`. Authored + user-validated at decompose (and whenever a task is created mid-execution); shown on the dashboard Home (Agora task table) and the Initiative-detail tasks table. Generated in the install-configured language; backfill detector = scripts/find-missing-task-summaries.js. Never hand-authored as a one-off outside the skill loop (skills/core/project.md → Task summaries)." },
        "description": { "type": "string" },
        "status": {
          "type": "string",
          "enum": ["pending", "active", "done", "blocked"]
        },
        "lastUpdated": { "$ref": "common.schema.json#/$defs/isoTimestamp" },
        "closedAt": { "$ref": "common.schema.json#/$defs/isoTimestamp" },
        "blockedBy": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "outputs": {
          "type": "array",
          "items": { "$ref": "#/$defs/taskOutput" }
        },
        "tags": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "resourceCounts": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "scopeBoundary": {
          "description": "Explicit exclusions — what this task must NOT do. Prevents scope creep at the task level.",
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "acceptance": {
          "description": "Executable acceptance criteria in it()-style assertions. Max 5 items.",
          "type": "array",
          "maxItems": 5,
          "items": { "type": "string", "minLength": 1 }
        },
        "verifier": { "$ref": "common.schema.json#/$defs/exitCriterionVerifier" },
        "evidence": {
          "$ref": "common.schema.json#/$defs/exitCriterion/properties/evidence",
          "description": "0.2 (F-B4): captured result of running this task's `verifier` on `done <task-id>`, reusing the exact exitCriterion.evidence shape. Replaces the v0.1 description-note string-laundering workaround so per-task verifier results are machine-enforceable (GATE-R2)."
        },
        "provenance": { "$ref": "common.schema.json#/$defs/provenance" },
        "context": { "$ref": "common.schema.json#/$defs/context" }
      },
      "allOf": [
        {
          "description": "Tasks added mid-execution (with provenance) must articulate WHY via context. Original-materialization tasks live without context — their narrative is the plan/initiative body.",
          "if": { "required": ["provenance"] },
          "then": { "required": ["context"] }
        }
      ]
    },
    "taskOutput": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["command", "file", "migration", "json", "test"]
        },
        "path": { "type": "string" },
        "command": { "type": "string" },
        "description": { "type": "string" }
      }
    }
  }
}
