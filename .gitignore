*.swp
*.swo
*~
node_modules/
# Keep bundled demo fixtures tracked. Also keeps install.js from re-adding a
# /.atomic-skills/ ignore (it skips when '.atomic-skills/' already appears here).
!/assets/demo-fixtures/.atomic-skills/
.agents/
.claude/settings.local.json
.claude/scheduled_tasks.lock
.cursor/
.gemini/
.opencode/
*:Zone.Identifier
nexus.yaml
.superpowers/
*.annotations.yaml

# Dogfooding artifacts: running `atomic-skills install` in this repo writes its
# install footprint + caches in-tree. These are generated, not source (the skill
# sources live in skills/), so keep them out of the published package. The rest
# of .atomic-skills/ (plans, initiatives, reviews) IS tracked on purpose.
.claude/skills/
.atomic-skills/manifest.json
.atomic-skills/version-cache.json
# Regenerable dashboard projection emitted by scripts/emit-consumer-state.js
# (the aiDeck consumer reads these; the emitter rebuilds them from the tracked
# plans/initiatives, so they are output, not source).
.atomic-skills/.aideck/

# Build artifacts
dist/*
node_modules/
.DS_Store
