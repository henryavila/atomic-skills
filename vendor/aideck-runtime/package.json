{
  "name": "@henryavila/aideck",
  "version": "0.0.1",
  "description": "AI-native dashboard runtime for developer workflows.",
  "type": "module",
  "bin": {
    "aideck": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schemas": {
      "types": "./dist/schemas/index.d.ts",
      "import": "./dist/schemas/index.js"
    },
    "./mcp": {
      "types": "./dist/mcp/index.d.ts",
      "import": "./dist/mcp/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "tsx watch src/server/index.ts",
    "build": "tsc -p tsconfig.server.json",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "chokidar": "^4.0.0",
    "hono": "^4.6.0",
    "open": "^10.1.0",
    "yaml": "^2.5.0",
    "zod": "^3.23.0",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^2.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "ai",
    "dashboard",
    "mcp",
    "claude",
    "agent",
    "developer-tools",
    "local-first"
  ],
  "license": "MIT",
  "author": "Henry Avila <personal@henryavila.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/henryavila/aideck.git"
  }
}
