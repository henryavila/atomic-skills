{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": [
    "src/server/**/*",
    "src/mcp/**/*",
    "src/schemas/**/*",
    "src/demo/**/*",
    "src/cli.ts",
    "src/cli/**/*"
  ],
  "exclude": ["src/client/**/*", "node_modules", "dist", "tests"]
}
